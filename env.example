# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Strapi Server Configuration (серверная сторона)
STRAPI_BASE_URL= https://boxpro.moscow/strapi
STRAPI_API_BASE_URL=http://localhost:1337/strapi/api
STRAPI_API_TOKEN=your_strapi_api_token_here

# Опционально: секретный ключ для доступа к YML-фиду (/api/feed/yml?key=...)
# FEED_SECRET_KEY=your_secret_key

# VK API (для загрузки городов при сборке)
VK_ACCESS_TOKEN=your_vk_service_token_here

# Strapi Client Configuration (клиентская сторона, NEXT_PUBLIC_*)
NEXT_PUBLIC_STRAPI_API_URL=http://localhost:1337/strapi/api
NEXT_PUBLIC_API_URL=http://localhost:1337